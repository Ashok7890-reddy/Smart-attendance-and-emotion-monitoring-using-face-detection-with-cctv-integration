# Environment Configuration for Smart Attendance System

# Application Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_attendance
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=10

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# WebSocket Configuration
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8001

# Camera Configuration
GATE_CAMERA_ID=gate_cam_01
CLASSROOM_CAMERA_IDS=class_cam_01,class_cam_02
CAMERA_FRAME_RATE=30
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080
CAMERA_RECONNECT_ATTEMPTS=3
CAMERA_RECONNECT_DELAY=5

# Face Recognition Configuration
FACE_MODEL_PATH=models/facenet.pb
FACE_CONFIDENCE_THRESHOLD=0.85
LIVENESS_THRESHOLD=0.7
FACE_MAX_PROCESSING_TIME=2
FACE_EMBEDDING_DIM=512

# Emotion Analysis Configuration
EMOTION_MODEL_PATH=models/emotion_classifier.h5
EMOTION_CONFIDENCE_THRESHOLD=0.6
EMOTION_UPDATE_INTERVAL=5

# Security Configuration
ENCRYPTION_KEY=your_encryption_key_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=3600
API_RATE_LIMIT=100
ENABLE_AUDIT_LOGGING=true

# File Paths
MODELS_DIR=models
LOGS_DIR=logs
DATA_DIR=data

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8001